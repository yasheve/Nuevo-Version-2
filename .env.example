# -- NuEvo Asset Capture API -- environment --------------------------------
# Local dev: copy to .env (every value has a safe local default).
# PRODUCTION (Render/etc.): set these as real environment variables in the
# host dashboard. Do NOT commit a filled-in .env to Git.

# -- Database -------------------------------------------------------------
# Local dev uses SQLite automatically. Production (Neon), +psycopg form:
# DATABASE_URL=postgresql+psycopg://USER:PASS@HOST/DBNAME?sslmode=require

# -- Auth -----------------------------------------------------------------
# CHANGE THIS in production (any long random string).
JWT_SECRET=dev-only-change-me-in-production
ACCESS_TTL_HOURS=12

# -- CORS -----------------------------------------------------------------
# The PWA's origin(s). "*" for dev only; list them in production:
# CORS_ORIGINS=https://capture.nuevo.co.za
CORS_ORIGINS=*

# -- Object storage (this build uses S3-compatible storage) ---------------
# REQUIRED in production -- the app will not start without S3_BUCKET.
# (Cloudflare R2 example.)
# S3_BUCKET=nuevodatabase
# S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com   # R2/B2/MinIO only
# AWS_REGION=auto                                                # "auto" for R2
# AWS_ACCESS_KEY_ID=<scoped access key>
# AWS_SECRET_ACCESS_KEY=<scoped secret>
# PRESIGN_PUT_TTL_MIN=10
# SIGNED_GET_TTL_MIN=15

# -- Live nameplate OCR ---------------------------------------------------
# Leave blank to run in offline-fallback mode.
# ANTHROPIC_API_KEY=sk-ant-...
OCR_MODEL=claude-sonnet-4-6

# -- Demo seeding ---------------------------------------------------------
# Disable / change before real use.
SEED_ON_START=true
SEED_DEMO_PASSWORD=nuevo123
